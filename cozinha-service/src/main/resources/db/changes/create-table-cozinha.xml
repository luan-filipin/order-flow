<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001" author="luan">
        <createTable tableName="cozinha">

            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="id_pedido" type="UUID">
                <constraints nullable="false"/>
            </column>

            <column name="numero_mesa" type="INT">
                <constraints nullable="false"/>
            </column>

            <column name="items_pedido" type="TEXT">
                <constraints nullable="false"/>
            </column>

            <column name="status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>

            <column name="data_recebimento" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="data_fim_preparo" type="TIMESTAMP">
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>